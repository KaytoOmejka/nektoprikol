{
  "manifest_version": 3,
  "name": "nekto.me · голосовой мост",
  "version": "0.1.0",
  "description": "Связывает два голосовых чата nekto.me: собеседники слышат друг друга, а оператор слышит обоих и может говорить обоим сразу.",
  "browser_specific_settings": {
    "gecko": {
      "id": "nekto-voice-bridge@local",
      "strict_min_version": "115.0"
    }
  },
  "permissions": ["tabs"],
  "host_permissions": ["*://*.nekto.me/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.nekto.me/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://*.nekto.me/*"]
    }
  ]
}
